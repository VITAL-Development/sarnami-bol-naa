    "grammarNotes": [
      {
        "id": "gn-6-1",
        "title": "Stam, lange en langere vorm",
        "body": "Een bijvoeglijk naamwoord is een woord dat iets beschrijft, zoals 'klein' of 'rood'. Zo'n woord heeft in het Sarnami drie vormen. De stam is de neutrale vorm. Bijvoorbeeld: choṭā betekent 'klein'. De lange vorm eindigt op -kā. Bijvoorbeeld: chŏṭkā. De langere vorm eindigt op -kavā en legt extra nadruk. Bijvoorbeeld: chŏṭkāvā. In het district Nickerie gebruikt men vaak -kanā in plaats van -kavā. Bijvoorbeeld: chŏṭkanā.",
        "relatedVocab": [
          "adj-chota"
        ]
      }
    ],
