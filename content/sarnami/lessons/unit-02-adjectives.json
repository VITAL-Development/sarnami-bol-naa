    "grammarNotes": [
      {
        "id": "gn-7-1",
        "title": "Meervoud en vrouwelijke vorm",
        "body": "Een bijvoeglijk naamwoord neemt het getal (enkelvoud/meervoud) over van het zelfstandig naamwoord. Bijvoorbeeld: ū barkāvā perva (die grote boom) wordt in het meervoud ū barkāvan pervan (die grote bomen). Bij een vrouwelijk zelfstandig naamwoord krijgt het bijvoeglijk naamwoord vaak de uitgang -ī. Bijvoorbeeld: karikkanī bakariyā (de zwarte geit), lalkanī sariyā (de rode sari).",
        "relatedVocab": [
          "adj-barka",
          "adj-karikka"
        ]
      }
    ],
