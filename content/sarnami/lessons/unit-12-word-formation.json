    "grammarNotes": [
      {
        "id": "gn-wf-2",
        "title": "Achtervoegsels van Arabisch-Perzische oorsprong",
        "body": "Een deel van de Sarnami-woordvorming komt uit het Arabisch en Perzisch. Het achtervoegsel -dār betekent 'bezittend, houder van'. Bijvoorbeeld: dukān ('winkel') wordt dukāndār ('een winkelier'). Nog een voorbeeld: imān ('eer') wordt imāndār ('eerlijk'). -gar maakt een maker of doener. Bijvoorbeeld: jādū ('toverkunst') wordt jādūgar ('een goochelaar'). Nog een voorbeeld: kār ('werk') wordt kārīgar ('een vakman'). -khānā betekent 'huis, plaats'. Bijvoorbeeld: davā ('medicijn') wordt davā-khānā ('een apotheek'). Nog een voorbeeld: chap ('druk') wordt chapkhānā ('een drukkerij').",
        "relatedVocab": [
          "wf-imandar",
          "wf-jadugar",
          "wf-davakhana"
        ]
      },
      {
        "id": "gn-wf-3",
        "title": "Voorvoegsels van Arabisch-Perzische oorsprong",
        "body": "Dezelfde bron levert ook voorvoegsels die het tegendeel van een woord maken. Het voorvoegsel be- betekent 'zonder, -loos'. Bijvoorbeeld: cain ('rust') wordt becain ('radeloos'). nā- betekent 'on-, niet'. Bijvoorbeeld: lāyak ('geschikt') wordt nā-lāyak ('ongeschikt'). bad- betekent 'slecht-'. Bijvoorbeeld: nām ('naam') wordt badnāmī ('oneer'). Met deze voorvoegsels vorm je makkelijk het tegendeel van een woord.",
        "relatedVocab": [
          "wf-becain",
          "wf-nalayak"
        ]
      }
    ],
