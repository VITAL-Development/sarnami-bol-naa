    "grammarNotes": [
      {
        "id": "gn-09-1",
        "title": "Nevenschikkende voegwoorden",
        "body": "Deze voegwoorden verbinden twee gelijkwaardige delen van een zin — je noemt ze nevenschikkend. De belangrijkste zijn aur ('en'; ook auro, au), baki ('maar') en yā ('of'; ook ki, ki to). Voor 'ofwel' gebruik je yā to. Twee voegwoorden kunnen ook samen een vast paar vormen: kā … kā … ('zowel … als …') en nā … nā … ('noch … noch …'). Zulke voegwoorden veranderen nooit van vorm.",
        "relatedVocab": [
          "struct-en",
          "struct-maar",
          "struct-of",
          "conj-ofwel",
          "conj-zowel-als",
          "conj-noch-noch"
        ]
      }
    ],
