    "grammarNotes": [
      {
        "id": "gn-post-1",
        "title": "Achterzetsel, geen voorzetsel",
        "body": "Het Sarnami plaatst het achterzetsel ACHTER het woord. Het Nederlands doet dat anders: daar komt het voorzetsel VÓÓR het woord. Zo wordt 'in huis' letterlijk 'huis in': ghar meṁ. En 'op het huis' wordt ghar par. Onthoud dus: eerst het naam- of voornaamwoord, dan het achterzetsel.",
        "relatedVocab": [
          "post-mem",
          "post-par",
          "noun-ghar"
        ]
      },
      {
        "id": "gn-post-2",
        "title": "De primaire achterzetsels",
        "body": "Er zijn vier korte, primaire achterzetsels: meṁ (in), se (met, door, uit, aan), par of pe (op) en ke (van, aan). Ze bestaan uit één woordje en staan direct achter het naamwoord. Het achterzetsel se is bijzonder veelzijdig en dekt meerdere Nederlandse voorzetsels tegelijk.",
        "relatedVocab": [
          "post-mem",
          "post-se",
          "post-par",
          "post-ke"
        ]
      },
      {
        "id": "gn-post-3",
        "title": "Samengestelde achterzetsels met ke",
        "body": "Er bestaan ook samengestelde achterzetsels. Je bouwt ze met ke: ke uppar (boven), ke nicce (onder), ke bhittar (binnen), ke bāhar (buiten). Ze geven vaak een plaats aan. Soms valt de ke weg. In de standaardvorm staat hij er wel: ghar ke uppar (boven het huis).",
        "relatedVocab": [
          "post-ke-uppar",
          "post-ke-nicce",
          "post-ke-bhittar",
          "post-ke-bahar"
        ]
      }
    ],
